# Relay HTTP base for the browser app (no trailing slash).
VITE_RELAY_HTTP_BASE=http://127.0.0.1:8008

# Optional Vite dev-proxy form if you run a local relay behind `/__relay`.
# VITE_RELAY_HTTP_BASE=/__relay

# Do not put RELAY_CONTROL_TOKEN in Vite env — it would be baked into the JS bundle.
# Use the PWA "Control token" field (stored in localStorage) instead.
